# Copia este archivo a ".env" y pon tu clave.
# Clave gratis (sin tarjeta): https://aistudio.google.com/apikey
GEMINI_API_KEY=pon_tu_clave_aqui

# Opcional: modelo a usar. Default: gemini-3.1-flash-lite (única opción con
# cuota diaria free tier utilizable, verificado 2026-07-20).
# NO usar: gemini-2.0/2.5-flash (retirados, 429 limit: 0) ni
# gemini-flash-latest (-> 3.5-flash: solo 20 requests/DÍA gratis).
# YACHAQ_MODEL=gemini-3.1-flash-lite

# Opcional: en quechua, añadir línea [ES] para el docente (1=sí, 0=no)
# YACHAQ_QU_GLOSS=1

# --- Modo offline (aula sin señal) ---
# Activo por defecto: cada turno intenta Gemini con timeout corto y, si
# falla, cae al banco local pre-cargado con `python precache.py`.
# YACHAQ_OFFLINE=1
# YACHAQ_FALLBACK_TIMEOUT=12      # segundos antes de caer al banco local
# YACHAQ_FALLBACK_RETRIES=1       # intentos online por turno
# YACHAQ_MATCH_THRESHOLD=0.45     # puntaje mínimo (0-1) para usar el banco
